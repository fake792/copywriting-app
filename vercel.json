{
  "name": "copywriting-app",
  "version": 2,
  "builds": [
    {
      "src": "index.html",
      "use": "@vercel/static"
    },
    {
      "src": "pro-upgrade.html",
      "use": "@vercel/static"
    },
    {
      "src": "server/server.js",
      "use": "@vercel/node"
    }
  ],
  "routes": [
    { "src": "/", "dest": "/index.html" },
    { "src": "/upgrade", "dest": "/pro-upgrade.html" },
    { "src": "/api/(.*)", "dest": "/server/server.js" }
  ]
}
