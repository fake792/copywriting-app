{
  "name": "copywriting-app",
  "version": 2,
  "builds": [
    {
      "src": "index.html",
      "use": "@vercel/static"
    },
    {
      "src": "pro-upgrade.html",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    { "src": "/", "dest": "/index.html" },
    { "src": "/upgrade", "dest": "/pro-upgrade.html" },
    {
      "src": "/api/(.*)",
      "dest": "https://copywriting-api.railway.app/api/$1"
    }
  ],
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "https://copywriting-api.railway.app/api/:path*"
    }
  ]
}
